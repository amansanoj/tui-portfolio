# Notion integration token used to fetch projects and certifications.
NOTION_API_KEY=

# Optional path to the SSH host private key.
# Defaults to /data/host_key when unset.
HOST_KEY_PATH=/data/host_key

# Optional SSH listen address.
# Defaults to 0.0.0.0:22 when unset.
APP_ADDR=0.0.0.0:22

# Optional graceful shutdown timeout in seconds.
# Must be a positive integer. Defaults to 30.
SHUTDOWN_TIMEOUT_SECONDS=30

# Optional Notion database IDs.
# If unset, built-in defaults are used.
NOTION_PROJECTS_DB_ID=
NOTION_CERTS_DB_ID=
